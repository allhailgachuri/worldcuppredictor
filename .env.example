# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed Lovable/Antigravity/Streamlit URL here once you have one.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Where the frontend (Streamlit quickstart) finds the API.
API_URL=http://localhost:8000

# Optional: only needed if you wire up Phase 7 (Supabase prediction logging).
# Use the SERVICE key here, never the anon key, and never commit this file.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
